#!/usr/bin/env python3
"""daedalus — run the autonomous composition search for a task spec.

    bin/daedalus run specs/pr-review/taskspec.toml \
        [--budget-usd 2.0] [--max-candidates 6] [--trials 3] \
        [--optimizer-model moonshotai/kimi-k2.6] [--arena PATH]

Stages: validate rig (oracle/null) → baselines on train+validation →
reflective single-slot search loop → holdout final for the Pareto front →
report.md + pareto.json + loop.json. Stops at budget, plateau, proposal
failures, or the candidate cap.
"""

import argparse
import json
import subprocess
import sys
import tomllib
from datetime import datetime, timezone
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO / "runner"))

import loop  # noqa: E402
import mutate  # noqa: E402
import report  # noqa: E402
from run import summarize  # noqa: E402

BASELINES = ["candidates/pi-kimi.toml"]
REFERENCES = ["candidates/oracle.toml", "candidates/null.toml"]
PROBE = "candidates/probe-oneshot.toml"


def sh_runner(manifest, arena_dir, exp_dir, split, trials, final=False):
    cmd = [
        sys.executable,
        str(REPO / "runner" / "run.py"),
        "--candidate", str(manifest),
        "--arena", str(arena_dir),
        "--exp-dir", str(exp_dir),
        "--trials", str(trials),
        "--split", split,
    ]
    if final:
        cmd.append("--final")
    print(f"\n=== run {Path(manifest).stem} split={split} trials={trials}", flush=True)
    proc = subprocess.run(cmd, cwd=REPO)
    if proc.returncode != 0:
        sys.exit(f"runner failed for {manifest} (split={split})")


def load_records(exp_dir):
    path = exp_dir / "trials.jsonl"
    if not path.exists():
        return []
    return [json.loads(line) for line in path.read_text().splitlines()]


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    sub = parser.add_subparsers(dest="command", required=True)
    run_p = sub.add_parser("run", help="search compositions for a task spec")
    run_p.add_argument("taskspec")
    run_p.add_argument("--arena", help="override arena dir (default: spec fixtures)")
    run_p.add_argument("--budget-usd", type=float, default=2.0)
    run_p.add_argument("--max-candidates", type=int, default=6)
    run_p.add_argument("--trials", type=int, default=3)
    run_p.add_argument("--optimizer-model", default="moonshotai/kimi-k2.6")
    run_p.add_argument("--plateau", type=int, default=2)
    run_p.add_argument(
        "--allow-saturated",
        action="store_true",
        help="search even when the one-shot probe rivals the oracle "
        "(scores from a saturated arena cannot rank agents)",
    )
    args = parser.parse_args()

    spec = tomllib.loads(Path(args.taskspec).read_text())
    arena_dir = Path(args.arena) if args.arena else (
        REPO / spec["inputs"]["fixtures"]
    )
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    exp_dir = REPO / "runs" / f"{stamp}-search-{spec['id']}"
    exp_dir.mkdir(parents=True)
    manifests = {"pi-kimi": REPO / BASELINES[0]}
    optimizer_costs = []

    # --- Stage 1: validate the rig (references + saturation probe) ---
    print("== stage 1: rig validation (oracle ceiling, null floor)", flush=True)
    for ref in REFERENCES:
        sh_runner(REPO / ref, arena_dir, exp_dir, split="all",
                  trials=1, final=True)
    rig = summarize(exp_dir / "trials.jsonl")
    oracle_mean = rig["oracle"]["reward_mean"]
    null_mean = rig["null"]["reward_mean"]
    if oracle_mean != 1.0:
        sys.exit(f"rig broken: oracle scored {oracle_mean}, not 1.0")
    # The arena must discriminate: reporting nothing (null) must score strictly
    # worse than the oracle. (Null's score equals the clean-task fraction, so an
    # absolute threshold would wrongly reject small arenas with a clean task.)
    if null_mean >= oracle_mean:
        sys.exit(f"rig broken: null scored {null_mean} == oracle (no discrimination)")

    # Saturation probe: one inlined-context completion, no agent loop. If it
    # rivals the oracle, no score from this arena can rank agent compositions
    # — searching it would optimize noise (comparisons are agent vs agent).
    print("== stage 1b: saturation probe (one-shot reference)", flush=True)
    sh_runner(REPO / PROBE, arena_dir, exp_dir, split="all", trials=1, final=True)
    rig = summarize(exp_dir / "trials.jsonl")
    probe_mean = rig["probe-oneshot"]["reward_mean"]
    saturated = probe_mean >= oracle_mean - 0.1
    (exp_dir / "rig.json").write_text(json.dumps(
        {"oracle_mean": oracle_mean, "null_mean": null_mean,
         "probe_mean": probe_mean, "saturated": saturated}, indent=2))
    if saturated:
        print(
            f"!! ARENA SATURATED: probe scored {probe_mean} vs oracle "
            f"{oracle_mean}. This arena cannot rank agent configurations.",
            flush=True,
        )
        if not args.allow_saturated:
            sys.exit("aborting search on a saturated arena "
                     "(--allow-saturated to override)")

    # --- Stage 2: baselines on the search splits ---
    print("== stage 2: baselines on train+validation", flush=True)
    for cid, manifest in manifests.items():
        for split in ("train", "validation"):
            sh_runner(manifest, arena_dir, exp_dir, split, args.trials)

    # --- Stage 3: the search loop ---
    print("== stage 3: reflective search", flush=True)
    taskspec_for_prompt = {"goal": spec.get("goal"), "mode": spec.get("mode")}

    def summary_fn():
        return summarize(exp_dir / "trials.jsonl")

    def propose_fn(parent_id, generation):
        child_id = f"gen{generation}-{parent_id}"[:48]
        snapshot = json.loads(
            (exp_dir / "compositions" / f"{parent_id}.json").read_text()
        )
        parent_manifest = tomllib.loads(manifests[parent_id].read_text())
        manifest_path, meta = mutate.propose(
            taskspec_for_prompt,
            snapshot,
            parent_manifest,
            load_records(exp_dir),
            exp_dir,
            child_id,
            args.optimizer_model,
            packets_dir=exp_dir / "packets",
            manifests_dir=exp_dir / "manifests",
            archive_summary={
                cid: {"reward_mean": v["reward_mean"],
                      "cost_usd_total": v["cost_usd_total"]}
                for cid, v in summary_fn().items()
            },
        )
        manifests[child_id] = manifest_path
        optimizer_costs.append(meta.get("optimizer_cost_usd"))
        print(
            f"  proposed {child_id}: slot={meta['slot_changed']} — "
            f"{meta['hypothesis']}",
            flush=True,
        )
        return child_id, meta

    def run_child_fn(child_id):
        for split in ("train", "validation"):
            sh_runner(manifests[child_id], arena_dir, exp_dir, split, args.trials)

    outcome = loop.run_search(
        summary_fn=summary_fn,
        propose_fn=propose_fn,
        run_child_fn=run_child_fn,
        max_children=args.max_candidates,
        budget_usd=args.budget_usd,
        optimizer_costs=optimizer_costs,
        plateau_limit=args.plateau,
    )

    # --- Stage 4: holdout final for the Pareto front (skip if no holdout) ---
    holdout_ids = (tomllib.loads((arena_dir / "arena.toml").read_text())
                   .get("split", {}).get("holdout") or [])
    cands = report.aggregate(load_records(exp_dir))
    front = report.pareto_front(cands)
    if holdout_ids:
        print("== stage 4: holdout final evaluation", flush=True)
        for cid in front:
            sh_runner(manifests[cid], arena_dir, exp_dir, "holdout",
                      args.trials, final=True)
    else:
        print("== stage 4: skipped (arena declares no holdout tasks)", flush=True)

    # --- Stage 5: report + receipts ---
    print("== stage 5: report", flush=True)
    cands = report.aggregate(load_records(exp_dir))
    front = report.pareto_front(cands)
    pick = report.recommend(cands, front)
    report_text = report.render(cands, front, pick)
    if saturated:
        report_text = (
            "> **WARNING — arena saturated.** The one-shot probe scored "
            f"{probe_mean} vs oracle {oracle_mean}; rewards here cannot rank "
            "agent configurations. Fix the arena before trusting this table.\n\n"
        ) + report_text
    (exp_dir / "report.md").write_text(report_text)
    (exp_dir / "pareto.json").write_text(json.dumps(
        [
            {
                "candidate_id": cid,
                "composition_hash": cands[cid]["hash"],
                "reward_mean": cands[cid]["reward_mean"],
                "cost_usd_total": cands[cid]["cost"],
                "wall_mean_s": cands[cid]["wall_mean"],
                "recommended": cid == pick,
            }
            for cid in front
        ],
        indent=2,
    ))
    outcome["recommended"] = pick
    outcome["pareto_front"] = front
    (exp_dir / "loop.json").write_text(json.dumps(outcome, indent=2))

    print(f"\nstop reason: {outcome['stop_reason']}", flush=True)
    print(f"recommended: {pick}", flush=True)
    print(f"known spend: ${outcome['spend_known_usd']}", flush=True)
    print(f"experiment:  {exp_dir.relative_to(REPO)}", flush=True)


if __name__ == "__main__":
    main()
