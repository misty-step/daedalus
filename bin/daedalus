#!/usr/bin/env python3
"""daedalus — run the autonomous composition search for a task spec.

    bin/daedalus run specs/pr-review/taskspec.toml \
        [--budget-usd 2.0] [--max-candidates 6] [--trials 3] \
        [--optimizer-model moonshotai/kimi-k2.6] [--arena PATH]

Stages: validate rig (oracle/null + one-shot saturation probe) → seed a
diverse agent population from the taskspec [search] space → reflective
single-slot search loop → holdout final for the Pareto front → report.md +
pareto.json + loop.json. Stops at budget, plateau, proposal failures, or the
candidate cap. Comparisons are agent vs agent throughout; references never
compete.
"""

import argparse
import json
import subprocess
import sys
import tomllib
from datetime import datetime, timezone
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO / "runner"))

import doctor as doctor_mod  # noqa: E402
import export as export_mod  # noqa: E402
import launch as launch_mod  # noqa: E402
import lineage  # noqa: E402
import loop  # noqa: E402
import mutate  # noqa: E402
import report  # noqa: E402
import seed  # noqa: E402
import swarm as swarm_mod  # noqa: E402
import taxonomy as taxonomy_mod  # noqa: E402
import trace as trace_mod  # noqa: E402
import workbench as workbench_mod  # noqa: E402
from run import summarize  # noqa: E402

REFERENCES = ["candidates/oracle.toml", "candidates/null.toml"]
PROBE = "candidates/probe-oneshot.toml"
# Fraction of the budget the landscape scan may consume before the
# reflective search takes over.
SEED_BUDGET_FRACTION = 0.6


def sh_runner(manifest, arena_dir, exp_dir, split, trials, final=False,
              max_errors=None):
    cmd = [
        sys.executable,
        str(REPO / "runner" / "run.py"),
        "--candidate", str(manifest),
        "--arena", str(arena_dir),
        "--exp-dir", str(exp_dir),
        "--trials", str(trials),
        "--split", split,
    ]
    if final:
        cmd.append("--final")
    if max_errors is not None:
        cmd += ["--max-errors", str(max_errors)]
    print(f"\n=== run {Path(manifest).stem} split={split} trials={trials}", flush=True)
    proc = subprocess.run(cmd, cwd=REPO)
    if proc.returncode != 0:
        sys.exit(f"runner failed for {manifest} (split={split})")


def load_records(exp_dir):
    path = exp_dir / "trials.jsonl"
    if not path.exists():
        return []
    return [json.loads(line) for line in path.read_text().splitlines()]


def manifest_id(manifest):
    return tomllib.loads(Path(manifest).read_text())["id"]


def candidate_error_count(exp_dir, cid):
    return sum(
        1 for r in load_records(exp_dir)
        if r["candidate_id"] == cid and r.get("error")
    )


def record_cutoff(exp_dir, entry):
    with open(exp_dir / "candidate-cutoffs.jsonl", "a") as f:
        f.write(json.dumps(entry) + "\n")


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    sub = parser.add_subparsers(dest="command", required=True)
    run_p = sub.add_parser("run", help="search compositions for a task spec")
    run_p.add_argument("taskspec")
    run_p.add_argument("--arena", help="override arena dir (default: spec fixtures)")
    run_p.add_argument("--budget-usd", type=float, default=2.0)
    run_p.add_argument("--max-candidates", type=int, default=6)
    run_p.add_argument("--trials", type=int, default=3)
    run_p.add_argument("--optimizer-model", default="moonshotai/kimi-k2.6")
    run_p.add_argument("--plateau", type=int, default=2)
    run_p.add_argument(
        "--allow-saturated",
        action="store_true",
        help="search even when the one-shot probe rivals the oracle "
        "(scores from a saturated arena cannot rank agents)",
    )
    run_p.add_argument(
        "--rng-seed",
        type=int,
        help="fix the seed-sampling RNG for a reproducible landscape scan",
    )
    run_p.add_argument(
        "--children-per-gen",
        type=int,
        default=2,
        help="competing hypotheses raced per generation (default 2)",
    )
    run_p.add_argument(
        "--certify-top",
        type=int,
        default=3,
        help="candidates certified with extra trials before recommendation",
    )
    run_p.add_argument(
        "--certify-trials",
        type=int,
        default=5,
        help="minimum trials per search task a candidate needs to be "
        "recommendable (kills the winner's curse)",
    )
    run_p.add_argument(
        "--max-errors-per-candidate",
        type=int,
        help="stop measuring a non-reference candidate after N errored trials",
    )
    exp_p = sub.add_parser(
        "export", help="export a delivery as control-plane artifacts "
        "(launch contract + sprite persona)"
    )
    exp_p.add_argument("delivery", help="deliveries/<id> directory")
    exp_p.add_argument("--spec", required=True, help="taskspec TOML")
    suite_export_p = sub.add_parser(
        "export-suite",
        help="export a review-swarm suite contract from measured summary evidence",
    )
    suite_export_p.add_argument("delivery", help="deliveries/<id> directory")
    suite_export_p.add_argument("--suite", required=True, help="suite taskspec TOML")
    trace_p = sub.add_parser(
        "trace", help="render committed run records as trace.otel.json"
    )
    trace_p.add_argument("run_dir", help="runs/<experiment> directory")
    launch_p = sub.add_parser(
        "launch-pack",
        help="emit approval-aware control-plane import packets",
    )
    launch_p.add_argument("delivery", help="deliveries/<id> directory")
    launch_p.add_argument(
        "--plane",
        required=True,
        choices=["bitter-blossom", "olympus"],
        help="target control plane packet shape",
    )
    launch_p.add_argument(
        "--dry-run",
        action="store_true",
        help="emit a sandbox-only packet even while G3 is unsigned",
    )
    launch_p.add_argument("--out-dir", help="output directory")
    regression_p = sub.add_parser(
        "regression",
        help="replay a delivery against the arena holdout and emit trace output",
    )
    regression_p.add_argument("delivery", help="deliveries/<id> directory")
    regression_p.add_argument("--spec", required=True, help="taskspec TOML")
    regression_p.add_argument("--trials", type=int, default=5)
    regression_p.add_argument("--exp-dir", help="existing/new regression run dir")
    regression_p.add_argument(
        "--dry-run",
        action="store_true",
        help="write the exact replay command without spending model budget",
    )
    scaffold_p = sub.add_parser(
        "arena-scaffold",
        help="create Harbor-format task placeholders for arena authoring",
    )
    scaffold_p.add_argument("arena", help="arenas/<id> directory")
    scaffold_p.add_argument("task_id", help="new task id")
    scaffold_p.add_argument(
        "--taskspec",
        default="specs/TODO/taskspec.toml",
        help="taskspec pointer for a new arena.toml",
    )
    validate_p = sub.add_parser(
        "arena-validate",
        help="validate an arena freeze gate without model spend",
    )
    validate_p.add_argument("arena", help="arenas/<id> directory")
    validate_p.add_argument(
        "--probe-run",
        help="runs/<id> directory containing oracle/null/one-shot records",
    )
    validate_p.add_argument(
        "--holdout-burn",
        type=int,
        default=5,
        help="holdout exposure threshold before rotation is required",
    )
    validate_p.add_argument("--report", help="write a markdown freeze report")
    adjudicate_p = sub.add_parser(
        "arena-adjudicate",
        help="append an ACCEPT or OUT-OF-SCOPE answer-key adjudication",
    )
    adjudicate_p.add_argument("arena", help="arenas/<id> directory")
    adjudicate_p.add_argument("--task", required=True)
    adjudicate_p.add_argument("--finding", required=True)
    adjudicate_p.add_argument(
        "--ruling",
        required=True,
        choices=["ACCEPT", "OUT-OF-SCOPE"],
    )
    adjudicate_p.add_argument("--rationale", required=True)
    adjudicate_p.add_argument("--new-version")
    adjudicate_p.add_argument("--baseline-run")
    disagreement_p = sub.add_parser(
        "arena-disagreements",
        help="report category/span misses for findings vs an answer key",
    )
    disagreement_p.add_argument("--findings", required=True)
    disagreement_p.add_argument("--expected", required=True)
    taxonomy_p = sub.add_parser(
        "taxonomy-validate",
        help="validate a review-swarm taxonomy against a suite taskspec",
    )
    taxonomy_p.add_argument("taxonomy", help="docs/review-swarm-taxonomy.md")
    taxonomy_p.add_argument("--suite", required=True, help="suite taskspec TOML")
    doctor_p = sub.add_parser(
        "doctor",
        help="print cold-start readiness checks without model spend",
    )
    doctor_p.add_argument(
        "--stale-days",
        type=int,
        default=30,
        help="maximum age for docs/primitives.md model verification",
    )
    doctor_p.add_argument(
        "--today",
        help="override current date for tests, YYYY-MM-DD",
    )
    args = parser.parse_args()

    if args.command == "export":
        spec = tomllib.loads(Path(args.spec).read_text())
        paths = export_mod.export_delivery(Path(args.delivery), spec)
        for kind, path in paths.items():
            print(f"{kind}: {path}")
        return
    if args.command == "export-suite":
        suite_spec = tomllib.loads(Path(args.suite).read_text())
        try:
            paths = swarm_mod.export_suite(Path(args.delivery), suite_spec)
        except swarm_mod.SwarmValidationError as exc:
            sys.exit(f"export-suite failed: {exc}")
        for kind, path in paths.items():
            print(f"{kind}: {path}")
        return
    if args.command == "trace":
        out = trace_mod.write_trace(Path(args.run_dir))
        print(f"trace: {out}")
        return
    if args.command == "launch-pack":
        try:
            out = launch_mod.write_import_packet(
                Path(args.delivery),
                plane=args.plane,
                dry_run=args.dry_run,
                out_dir=Path(args.out_dir) if args.out_dir else None,
            )
        except launch_mod.UnsignedLaunchError as exc:
            sys.exit(f"launch refused: {exc} (use --dry-run for review artifacts)")
        print(f"import_packet: {out}")
        return
    if args.command == "regression":
        spec = tomllib.loads(Path(args.spec).read_text())
        arena_dir = REPO / spec["inputs"]["fixtures"]
        stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
        exp_dir = Path(args.exp_dir) if args.exp_dir else (
            REPO / "runs" / f"{stamp}-regression-{spec['id']}"
        )
        cmd = [
            sys.executable,
            str(REPO / "runner" / "run.py"),
            "--candidate",
            str(Path(args.delivery) / "agent.toml"),
            "--arena",
            str(arena_dir),
            "--exp-dir",
            str(exp_dir),
            "--split",
            "holdout",
            "--trials",
            str(args.trials),
            "--final",
        ]
        if args.dry_run:
            exp_dir.mkdir(parents=True, exist_ok=True)
            plan = exp_dir / "regression-command.txt"
            display_cmd = [
                "python3",
                "runner/run.py",
                "--candidate",
                str(Path(args.delivery) / "agent.toml"),
                "--arena",
                spec["inputs"]["fixtures"],
                "--exp-dir",
                str(exp_dir),
                "--split",
                "holdout",
                "--trials",
                str(args.trials),
                "--final",
            ]
            plan.write_text(" ".join(display_cmd) + "\n")
            print(f"regression_command: {plan}")
            return
        proc = subprocess.run(cmd, cwd=REPO)
        if proc.returncode != 0:
            sys.exit(f"regression failed for {args.delivery}")
        trace_out = trace_mod.write_trace(exp_dir)
        print(f"regression: {exp_dir}")
        print(f"trace: {trace_out}")
        return
    if args.command == "arena-scaffold":
        task = workbench_mod.scaffold_task(
            Path(args.arena), args.task_id, taskspec=args.taskspec
        )
        print(f"task: {task}")
        return
    if args.command == "arena-validate":
        result = workbench_mod.validate_arena(
            Path(args.arena),
            probe_run=Path(args.probe_run) if args.probe_run else None,
            holdout_burn=args.holdout_burn,
        )
        text = workbench_mod.render_validation_report(result)
        if args.report:
            Path(args.report).write_text(text)
            print(f"freeze report: {args.report}")
        else:
            print(text)
        if not result.ok:
            sys.exit("arena validation failed")
        return
    if args.command == "arena-adjudicate":
        path = workbench_mod.record_adjudication(
            Path(args.arena),
            task=args.task,
            finding=args.finding,
            ruling=args.ruling,
            rationale=args.rationale,
            new_version=args.new_version,
            baseline_run=Path(args.baseline_run) if args.baseline_run else None,
        )
        print(f"adjudications: {path}")
        return
    if args.command == "arena-disagreements":
        rows = workbench_mod.disagreements(args.findings, args.expected)
        print(json.dumps(rows, indent=2))
        return
    if args.command == "taxonomy-validate":
        taxonomy_report = taxonomy_mod.validate_taxonomy(args.taxonomy, args.suite)
        print(taxonomy_mod.render_report(taxonomy_report))
        if not taxonomy_report.ok:
            sys.exit(1)
        return
    if args.command == "doctor":
        today = (
            datetime.strptime(args.today, "%Y-%m-%d").date()
            if args.today else None
        )
        checks = doctor_mod.run_checks(
            REPO, today=today, stale_days=args.stale_days
        )
        print(doctor_mod.render(checks), end="")
        if doctor_mod.has_failures(checks):
            sys.exit("doctor found blocking readiness issues")
        return

    spec = tomllib.loads(Path(args.taskspec).read_text())
    mode = spec.get("mode") or "max-quality"
    arena_dir = Path(args.arena) if args.arena else (
        REPO / spec["inputs"]["fixtures"]
    )
    arena_cfg = tomllib.loads((arena_dir / "arena.toml").read_text())
    split_cfg = arena_cfg.get("split") or {}
    search_tasks = (split_cfg.get("train") or []) + (
        split_cfg.get("validation") or []
    )
    holdout_ids = split_cfg.get("holdout") or []
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    exp_dir = REPO / "runs" / f"{stamp}-search-{spec['id']}"
    exp_dir.mkdir(parents=True)
    manifests = {}
    optimizer_costs = []

    def run_candidate_split(manifest, split, trials, final=False):
        cid = manifest_id(manifest)
        remaining = None
        if args.max_errors_per_candidate is not None:
            errors = candidate_error_count(exp_dir, cid)
            remaining = args.max_errors_per_candidate - errors
            if remaining <= 0:
                print(
                    f"  skip {cid} split={split}: max error limit "
                    f"{args.max_errors_per_candidate} already reached",
                    flush=True,
                )
                record_cutoff(exp_dir, {
                    "candidate_id": cid,
                    "split": split,
                    "errors": errors,
                    "max_errors_per_candidate": args.max_errors_per_candidate,
                    "reason": "max-errors-per-candidate",
                })
                return
        sh_runner(manifest, arena_dir, exp_dir, split, trials, final=final,
                  max_errors=remaining)

    # --- Stage 1: validate the rig (references + saturation probe) ---
    print("== stage 1: rig validation (oracle ceiling, null floor)", flush=True)
    for ref in REFERENCES:
        sh_runner(REPO / ref, arena_dir, exp_dir, split="all",
                  trials=1, final=True)
    rig = summarize(exp_dir / "trials.jsonl")
    oracle_mean = rig["oracle"]["reward_mean"]
    null_mean = rig["null"]["reward_mean"]
    if oracle_mean != 1.0:
        sys.exit(f"rig broken: oracle scored {oracle_mean}, not 1.0")
    # The arena must discriminate: reporting nothing (null) must score strictly
    # worse than the oracle. (Null's score equals the clean-task fraction, so an
    # absolute threshold would wrongly reject small arenas with a clean task.)
    if null_mean >= oracle_mean:
        sys.exit(f"rig broken: null scored {null_mean} == oracle (no discrimination)")

    # Saturation probe: one inlined-context completion, no agent loop. If it
    # rivals the oracle, no score from this arena can rank agent compositions
    # — searching it would optimize noise (comparisons are agent vs agent).
    print("== stage 1b: saturation probe (one-shot reference)", flush=True)
    sh_runner(REPO / PROBE, arena_dir, exp_dir, split="all", trials=1, final=True)
    rig = summarize(exp_dir / "trials.jsonl")
    probe_mean = rig["probe-oneshot"]["reward_mean"]
    saturated = probe_mean >= oracle_mean - 0.1
    (exp_dir / "rig.json").write_text(json.dumps(
        {"oracle_mean": oracle_mean, "null_mean": null_mean,
         "probe_mean": probe_mean, "saturated": saturated}, indent=2))
    if saturated:
        print(
            f"!! ARENA SATURATED: probe scored {probe_mean} vs oracle "
            f"{oracle_mean}. This arena cannot rank agent configurations.",
            flush=True,
        )
        if not args.allow_saturated:
            sys.exit("aborting search on a saturated arena "
                     "(--allow-saturated to override)")

    # --- Stage 2: seed a diverse agent population from the search space ---
    print("== stage 2: seed population (landscape scan)", flush=True)
    seeds, seed_meta = seed.seed_population(
        spec,
        args.optimizer_model,
        packets_dir=exp_dir / "packets",
        manifests_dir=exp_dir / "manifests",
        rng_seed=args.rng_seed,
    )
    optimizer_costs.extend(seed_meta["optimizer_costs"])
    (exp_dir / "seed.json").write_text(json.dumps(seed_meta, indent=2))
    print(f"  rng_seed={seed_meta['rng_seed']}  seeds={len(seeds)}", flush=True)
    seed_budget = (args.budget_usd or 0) * SEED_BUDGET_FRACTION or None
    for sid, manifest in seeds:
        if seed_budget is not None:
            spent = loop.known_spend(
                summarize(exp_dir / "trials.jsonl"), optimizer_costs
            )
            if spent >= seed_budget:
                print(
                    f"  seed budget ${seed_budget:.2f} reached "
                    f"(${spent:.4f} spent); stopping before {sid}",
                    flush=True,
                )
                break
        manifests[sid] = manifest
        for split in ("train", "validation"):
            run_candidate_split(manifest, split, args.trials)
    if not manifests:
        sys.exit("no seeds ran within the seed budget; raise --budget-usd")

    # --- Stage 3: the search loop (competing hypotheses per generation) ---
    print("== stage 3: reflective search", flush=True)
    taskspec_for_prompt = {"goal": spec.get("goal"), "mode": spec.get("mode")}
    search_space = spec.get("search") or {}

    def summary_fn():
        return summarize(exp_dir / "trials.jsonl")

    def propose_fn(parent_id, generation, attempt, avoid_slots):
        child_id = f"g{generation}{'abcdefgh'[attempt]}-{parent_id}"[:48]
        snapshot = json.loads(
            (exp_dir / "compositions" / f"{parent_id}.json").read_text()
        )
        parent_manifest = tomllib.loads(Path(manifests[parent_id]).read_text())
        # Archive snapshots double as transplant donors: the search may move
        # one discovered slot value (packet text, model, tools...) onto the
        # parent instead of inventing a perturbation.
        archive = {}
        for snap_file in (exp_dir / "compositions").glob("*.json"):
            snap = json.loads(snap_file.read_text())
            if snap.get("kind") == "pi":
                archive[snap["id"]] = snap
        manifest_path, meta = mutate.propose(
            taskspec_for_prompt,
            snapshot,
            parent_manifest,
            load_records(exp_dir),
            exp_dir,
            child_id,
            args.optimizer_model,
            packets_dir=exp_dir / "packets",
            manifests_dir=exp_dir / "manifests",
            archive_summary={
                cid: {"reward_mean": v["reward_mean"],
                      "cost_usd_total": v["cost_usd_total"]}
                for cid, v in summary_fn().items()
            },
            tool_policies=search_space.get("tool_policies"),
            allowed_models=search_space.get("models"),
            allowed_thinking=search_space.get("thinking_levels"),
            avoid_slots=avoid_slots,
            skill_sets=search_space.get("skill_sets"),
            archive_manifests=archive,
            mode=mode,
        )
        manifests[child_id] = manifest_path
        optimizer_costs.append(meta.get("optimizer_cost_usd"))
        print(
            f"  proposed {child_id} (parent {parent_id}): "
            f"slot={meta['slot_changed']} — {meta['hypothesis']}",
            flush=True,
        )
        return child_id, meta

    def run_child_fn(child_id):
        for split in ("train", "validation"):
            run_candidate_split(manifests[child_id], split, args.trials)

    def monitor_fn(summary, generation):
        """In-loop meta-eval: notice when the arena, not the candidates, is
        the bottleneck."""
        alarms = []
        try:
            best = loop.best_candidate(summary)
        except ValueError:
            return alarms
        best_r = summary[best]["reward_mean"]
        if best_r >= 0.999:
            alarm = {
                "generation": generation,
                "kind": "saturation-at-top",
                "detail": f"{best} at reward {best_r}: no reward gradient "
                          "remains on the search splits",
            }
            if mode == "max-quality":
                alarm["stop"] = "arena-saturated-at-top"
            else:
                alarm["detail"] += "; continuing on cost/latency only"
            alarms.append(alarm)
        for cid, stats in summary.items():
            if loop.is_reference(cid, stats):
                continue
            for task, t in stats.get("tasks", {}).items():
                if t.get("min") == 0.0 and t.get("max") == 1.0:
                    alarms.append({
                        "generation": generation,
                        "kind": "variance",
                        "detail": f"{cid} flip-flops on {task} (trials span "
                                  "0.0–1.0); certification required",
                    })
        return alarms

    outcome = loop.run_search(
        summary_fn=summary_fn,
        propose_fn=propose_fn,
        run_child_fn=run_child_fn,
        max_children=args.max_candidates,
        budget_usd=args.budget_usd,
        optimizer_costs=optimizer_costs,
        plateau_limit=args.plateau,
        children_per_generation=args.children_per_gen,
        mode=mode,
        monitor_fn=monitor_fn,
    )

    # --- Stage 3.5: certification racing ---
    # Selection on small-n means inflates the winner (winner's curse). The
    # top-k under the declared mode earn real trial counts before anything
    # is recommendable.
    print("== stage 3.5: certification racing", flush=True)

    def task_count(records, cid, task):
        return sum(
            1 for r in records
            if r["candidate_id"] == cid and r["task_id"] == task
        )

    summary = summary_fn()
    real = {
        cid: v for cid, v in summary.items() if not loop.is_reference(cid, v)
    }

    def mode_key(cid):
        cpt = loop.cost_per_trial(real[cid])
        return (
            real[cid]["reward_mean"],
            -(cpt if cpt is not None else float("inf")),
        )

    topk = [c for c in sorted(real, key=mode_key, reverse=True)
            if c in manifests][: args.certify_top]
    for cid in topk:
        spent = loop.known_spend(summary_fn(), optimizer_costs)
        if args.budget_usd is not None and spent >= args.budget_usd:
            print(f"  budget reached (${spent:.4f}); certification stops "
                  f"before {cid}", flush=True)
            break
        records = load_records(exp_dir)
        for split_name in ("train", "validation"):
            ids = split_cfg.get(split_name) or []
            if not ids:
                continue
            have = min(task_count(records, cid, t) for t in ids)
            need = args.certify_trials - have
            if need > 0:
                run_candidate_split(manifests[cid], split_name, need)

    # --- Stage 4: holdout final for the Pareto front (skip if no holdout) ---
    cands = report.aggregate(load_records(exp_dir))
    front = report.pareto_front(cands)
    if holdout_ids:
        print("== stage 4: holdout final evaluation", flush=True)
        exposed = [cid for cid in front if cid in manifests]
        for cid in exposed:
            run_candidate_split(manifests[cid], "holdout",
                                args.certify_trials, final=True)
        ledger = arena_dir / "holdout-ledger.md"
        if ledger.exists() and exposed:
            ledger_header = ledger.read_text().splitlines()[0]
            with open(ledger, "a") as f:
                f.write(workbench_mod.format_holdout_ledger_row(
                    stamp,
                    exp_dir.name,
                    exposed,
                    holdout_ids,
                    args.certify_trials,
                    arena_version=(
                        arena_cfg.get("version")
                        if "arena version" in ledger_header
                        else None
                    ),
                ))
    else:
        print("== stage 4: skipped (arena declares no holdout tasks)", flush=True)

    # --- Stage 5: report + receipts ---
    print("== stage 5: report", flush=True)
    records = load_records(exp_dir)
    cands = report.aggregate(records)
    front = report.pareto_front(cands)

    # Certified = enough trials on every search task that the mean is not a
    # lucky draw. Only certified candidates may be recommended.
    certified = {
        cid for cid, c in cands.items()
        if c["kind"] not in report.REFERENCE_KINDS
        and search_tasks
        and all(task_count(records, cid, t) >= args.certify_trials
                for t in search_tasks)
    }
    pick = report.recommend(cands, front, eligible=certified) if certified else None

    # Post-run meta-eval: an FP trap every agent passed never fired.
    alarms = list(outcome.get("alarms", []))
    clean_tasks = {
        r["task_id"] for r in records if r.get("expected_defects") == 0
    }
    for task in sorted(clean_tasks):
        agent_trials = [
            r for r in records
            if r["task_id"] == task and r.get("candidate_kind") == "pi"
        ]
        if agent_trials and all(r["reward"] == 1.0 for r in agent_trials):
            alarms.append({
                "kind": "fp-trap-never-fired",
                "detail": f"every agent passed clean task {task}; the trap "
                          "may be too easy to discriminate FP discipline",
            })
    outcome["alarms"] = alarms

    report_text = report.render(cands, front, pick)
    if certified:
        report_text += (
            f"\n_Certified (≥{args.certify_trials} trials per search task): "
            + ", ".join(sorted(certified))
            + ". Recommendation restricted to certified candidates._\n"
        )
    if alarms:
        report_text += "\n## Meta-eval alarms\n\n" + "".join(
            f"- **{a['kind']}**: {a['detail']}\n" for a in alarms
        )
        (exp_dir / "arena-findings.md").write_text(
            "# Draft arena-iteration note (promote to a backlog ticket)\n\n"
            f"Run: {exp_dir.name}  mode: {mode}\n\n" + "".join(
                f"- {a['kind']}: {a['detail']}\n" for a in alarms
            )
        )
    if saturated:
        report_text = (
            "> **WARNING — arena saturated.** The one-shot probe scored "
            f"{probe_mean} vs oracle {oracle_mean}; rewards here cannot rank "
            "agent configurations. Fix the arena before trusting this table.\n\n"
        ) + report_text
    cutoffs_path = exp_dir / "candidate-cutoffs.jsonl"
    if cutoffs_path.exists():
        cutoffs = [json.loads(line) for line in cutoffs_path.read_text().splitlines()]
        report_text += "\n## Candidate cutoffs\n\n" + "".join(
            "- `{candidate_id}` skipped split `{split}` after {errors} errors "
            "(limit {max_errors_per_candidate}).\n".format(**c)
            for c in cutoffs
        )
    total_known_spend = round(loop.known_spend(summary_fn(), optimizer_costs), 4)
    if optimizer_costs:
        report_text += (
            "\n## Spend accounting\n\n"
            f"Known spend including optimizer calls, certification, and holdout: "
            f"${total_known_spend:.4f}.\n"
        )
    (exp_dir / "report.md").write_text(report_text)
    (exp_dir / "pareto.json").write_text(json.dumps(
        [
            {
                "candidate_id": cid,
                "composition_hash": cands[cid]["hash"],
                "reward_mean": cands[cid]["reward_mean"],
                "cost_usd_total": cands[cid]["cost"],
                "cost_usd_per_trial": cands[cid]["cost_per_trial"],
                "wall_mean_s": cands[cid]["wall_mean"],
                "trials": cands[cid]["trials"],
                "certified": cid in certified,
                "recommended": cid == pick,
            }
            for cid in front
        ],
        indent=2,
    ))
    outcome["recommended"] = pick
    outcome["pareto_front"] = front
    outcome["certified"] = sorted(certified)
    outcome["spend_known_usd"] = total_known_spend
    (exp_dir / "loop.json").write_text(json.dumps(outcome, indent=2))

    # Lineage: the traceable story of how this contract was discovered.
    (exp_dir / "lineage.md").write_text(lineage.render(exp_dir))
    notebook = REPO / "runs" / "NOTEBOOK.md"
    if not notebook.exists():
        notebook.write_text(
            "# Lab notebook\n\nOne entry per run: what was tried, what was "
            "learned. lineage.md in each run dir has the full story.\n"
        )
    with open(notebook, "a") as f:
        f.write(lineage.notebook_entry(exp_dir, spec, arena_cfg))

    print(f"\nstop reason: {outcome['stop_reason']}", flush=True)
    print(f"recommended: {pick}"
          + ("" if pick in certified else "  (UNCERTIFIED)"), flush=True)
    print(f"certified:   {sorted(certified) or 'none'}", flush=True)
    print(f"known spend: ${outcome['spend_known_usd']}", flush=True)
    print(f"experiment:  {exp_dir.relative_to(REPO)}", flush=True)


if __name__ == "__main__":
    main()
