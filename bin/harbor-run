#!/usr/bin/env sh
# Run a Daedalus arena under Harbor's Docker isolation (real sandbox, parallel
# trials). Ports the arena to Harbor format using the Rust CLI (no Python),
# then runs one task or the whole dataset with the built-in pi or oracle agent.
# See docs/adr-001.
#
#   bin/harbor-run <arena-dir> <task-id|all> [--agent pi|oracle] [-m MODEL]
#
# Examples:
#   bin/harbor-run arenas/pr-review-v0 py-auth-sqli --agent oracle
#   bin/harbor-run arenas/pr-review-v0 all --agent pi -m openrouter/moonshotai/kimi-k2.6
set -eu
cd "$(dirname "$0")/.."

ARENA="$1"; TASK="$2"; shift 2
AGENT="oracle"; MODEL=""; PASS=""
while [ $# -gt 0 ]; do
    case "$1" in
        --agent) AGENT="$2"; shift 2 ;;
        -m|--model) MODEL="$2"; shift 2 ;;
        *) PASS="$PASS $1"; shift ;;
    esac
done

# Build the static musl scorer binary (no ring, fast after first build).
SCORER_BIN="target/x86_64-unknown-linux-musl/release/daedalus-score"
cargo build --release --target x86_64-unknown-linux-musl -p daedalus-score

# Port the arena using the Rust CLI.
cargo run --release -p daedalus-cli -- port-harbor "$ARENA" --scorer-bin "$SCORER_BIN"

# Extract arena id from arena.toml using the Rust score CLI (toml reader).
# Simpler: parse with grep/sed — arena.toml always has id = "..." on its own line.
ARENA_ID="$(grep '^id = ' "$ARENA/arena.toml" | sed 's/^id = "\(.*\)"/\1/')"

BUILD="harbor-build/$ARENA_ID"
[ "$TASK" = "all" ] && PATH_ARG="$BUILD" || PATH_ARG="$BUILD/$TASK"

set -- run -p "$PATH_ARG" --agent "$AGENT" --jobs-dir jobs -y
[ -n "$MODEL" ] && set -- "$@" -m "$MODEL"
if [ "$AGENT" = "pi" ] || [ "$AGENT" = "claude-code" ] || [ "$AGENT" = "codex" ]; then
    set -- "$@" --ae OPENROUTER_API_KEY="${OPENROUTER_API_KEY:-}"
fi
# shellcheck disable=SC2086
exec harbor "$@" $PASS
